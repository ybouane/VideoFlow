{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": ".",
    "declaration": true,
    "declarationMap": true,
    "composite": true,
    "paths": {
      "@videoflow/core": ["../core/index.ts"],
      "@videoflow/core/utils": ["../core/utils.ts"],
      "@videoflow/core/types": ["../core/types.ts"]
    }
  },
  "include": ["./**/*.ts", "./googlefonts.json"],
  "exclude": ["node_modules", "dist", "bundle-worker.ts"],
  "references": [
    { "path": "../core" }
  ]
}
