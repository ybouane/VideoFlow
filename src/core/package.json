{
  "name": "@videoflow/core",
  "version": "1.2.1",
  "description": "Turn JSON code into programmatic videos. Core library for VideoFlow — data model, layers, flow API, and video JSON compilation — Open Source Remotion alternative",
  "keywords": ["videoflow", "remotion", "ffmpeg", "video rendering", "video compilation", "video data model", "video layers", "video effects", "video transitions", "video editor", "video API"],
  "license": "Apache-2.0",
  "homepage": "https://videoflow.dev/core",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ybouane/VideoFlow.git",
    "directory": "src/core"
  },
  "bugs": {
    "url": "https://github.com/ybouane/VideoFlow/issues"
  },
  "type": "module",
  "files": ["dist", "README.md", "llms.txt", "llms-full.txt"],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./utils": {
      "types": "./dist/utils.d.ts",
      "import": "./dist/utils.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "import": "./dist/types.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json"
  },
  "devDependencies": {
    "typescript": "^5.7.0"
  }
}
